<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.TripDetailsController"
            prefWidth="720" prefHeight="760">

    <!-- TOP BAR -->
    <top>
        <VBox styleClass="topbar">
            <Label fx:id="titleLabel" styleClass="top-title"/>
            <HBox spacing="30">
                <Label fx:id="totalLabel" styleClass="top-sub"/>
                <Label fx:id="shareLabel" styleClass="top-sub"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>

        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent;">
            <VBox spacing="22" alignment="TOP_CENTER" padding="20">

                <!-- TABS INSIDE CARD -->
                <VBox styleClass="card" maxWidth="640">

                    <TabPane prefHeight="620">

                        <!-- TRAVELERS -->
                        <Tab text="👥 Travelers">
                            <VBox spacing="16">
                                <padding>
                                    <Insets top="15" right="15" bottom="15" left="15"/>
                                </padding>

                                <HBox spacing="10">
                                    <TextField fx:id="nameField" promptText="Enter traveler name"/>
                                    <Button text="+ Add Traveler" onAction="#addTraveler"/>
                                </HBox>

                                <TableView fx:id="table">
                                    <columns>
                                        <TableColumn fx:id="idCol" text="ID" prefWidth="80"/>
                                        <TableColumn fx:id="nameCol" text="Traveler Name" prefWidth="380"/>
                                    </columns>
                                </TableView>

                            </VBox>
                        </Tab>

                        <!-- EXPENSES -->
                        <Tab text="💳 Expenses">
                            <VBox spacing="16" padding="15">

                                <HBox spacing="10">
                                    <ComboBox fx:id="payerBox" promptText="Paid by"/>
                                    <TextField fx:id="amountField" promptText="Amount"/>
                                    <TextField fx:id="descField" promptText="Description"/>
                                    <Button text="Add Expense" onAction="#addExpense"/>
                                </HBox>

                                <TableView fx:id="expenseTable">
                                    <columns>
                                        <TableColumn fx:id="payerCol" text="Paid By" prefWidth="150"/>
                                        <TableColumn fx:id="amountCol" text="Amount" prefWidth="120"/>
                                        <TableColumn fx:id="descCol" text="Description" prefWidth="300"/>
                                    </columns>
                                </TableView>

                                <Button text="Delete Selected Expense"
                                        onAction="#deleteExpense"/>

                            </VBox>
                        </Tab>

                        <!-- SETTLEMENT -->
                        <Tab text="🧾 Settlement">
                            <VBox spacing="20" alignment="CENTER" padding="15">

                                <Button text="Calculate Split"
                                        prefWidth="240"
                                        prefHeight="48"
                                        onAction="#calculateSplit"/>

                                <TextArea fx:id="resultArea"
                                          wrapText="true"
                                          prefHeight="420"
                                          style="-fx-background-radius:14;"/>

                            </VBox>
                        </Tab>

                    </TabPane>

                </VBox>

            </VBox>
        </ScrollPane>

    </center>

</BorderPane>