<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.TripDetailsController"
      prefWidth="520" prefHeight="520">

    <padding>
        <Insets top="20" bottom="20" left="20" right="20"/>
    </padding>

    <Label fx:id="titleLabel"
           style="-fx-font-size:20px; -fx-font-weight:bold;"/>
    <Label fx:id="totalLabel" style="-fx-font-size:14px;"/>
    <Label fx:id="shareLabel" style="-fx-font-size:14px;"/>
    <!-- ADD TRAVELER -->
    <HBox spacing="10">
        <TextField fx:id="nameField" promptText="Traveler name"/>
        <Button text="Add Traveler" onAction="#addTraveler"/>
    </HBox>

    <TableView fx:id="table" prefHeight="120">
        <columns>
            <TableColumn fx:id="idCol" text="ID" prefWidth="80"/>
            <TableColumn fx:id="nameCol" text="Traveler Name" prefWidth="300"/>
        </columns>
    </TableView>

    <Separator/>

    <!-- ADD EXPENSE -->
    <HBox spacing="10">
        <ComboBox fx:id="payerBox" promptText="Paid by"/>
        <TextField fx:id="amountField" promptText="Amount"/>
        <TextField fx:id="descField" promptText="Description"/>
        <Button text="Add Expense" onAction="#addExpense"/>
    </HBox>

    <TableView fx:id="expenseTable" prefHeight="120">
        <columns>
            <TableColumn fx:id="payerCol" text="Paid By" prefWidth="120"/>
            <TableColumn fx:id="amountCol" text="Amount" prefWidth="100"/>
            <TableColumn fx:id="descCol" text="Description" prefWidth="180"/>
        </columns>
    </TableView>

    <Button text="Delete Selected Expense" onAction="#deleteExpense"/>
    <Button text="Calculate Split" onAction="#calculateSplit"/>

    <TextArea fx:id="resultArea" prefHeight="120"/>

</VBox>