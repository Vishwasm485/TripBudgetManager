<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="controller.TripDetailsController"
           prefWidth="1000"
           prefHeight="750"
           styleClass="root-bg">

    <BorderPane maxWidth="950" maxHeight="700"
                styleClass="main-container">

        <!-- ================= SIDEBAR ================= -->
        <left>
            <VBox spacing="30" styleClass="sidebar">
                <padding>
                    <Insets top="30" left="25" right="25" bottom="30"/>
                </padding>

                <Label fx:id="titleLabel" styleClass="logo-text"/>

                <Button text="Travelers" styleClass="side-btn"/>
                <Button text="Expenses" styleClass="side-btn"/>
                <Button text="Settlement" styleClass="side-btn"/>
            </VBox>
        </left>

        <!-- ================= CONTENT ================= -->
        <center>
            <VBox spacing="25">
                <padding>
                    <Insets top="30" left="30" right="30" bottom="30"/>
                </padding>

                <!-- Top Stats Cards -->
                <HBox spacing="20">

                    <VBox styleClass="stat-card">
                        <Label text="Total Cost" styleClass="stat-title"/>
                        <Label fx:id="totalLabel" styleClass="stat-value"/>
                    </VBox>

                    <VBox styleClass="stat-card">
                        <Label text="Per Person Share" styleClass="stat-title"/>
                        <Label fx:id="shareLabel" styleClass="stat-value"/>
                    </VBox>

                </HBox>

                <!-- Expenses Section -->
                <VBox styleClass="content-card" spacing="15">

                    <HBox spacing="10">
                        <ComboBox fx:id="payerBox" promptText="Paid by"/>
                        <TextField fx:id="amountField" promptText="Amount"/>
                        <TextField fx:id="descField" promptText="Description"/>
                        <Button text="Add" onAction="#addExpense" styleClass="primary-btn"/>
                    </HBox>

                    <TableView fx:id="expenseTable">
                        <columns>
                            <TableColumn fx:id="payerCol" text="Paid By" prefWidth="180"/>
                            <TableColumn fx:id="amountCol" text="Amount" prefWidth="140"/>
                            <TableColumn fx:id="descCol" text="Description" prefWidth="320"/>
                        </columns>
                    </TableView>

                    <Button text="Delete Selected"
                            onAction="#deleteExpense"
                            styleClass="danger-btn"/>
                </VBox>

                <!-- Settlement Section -->
                <VBox styleClass="content-card" spacing="15">

                    <Button text="Calculate Settlement"
                            onAction="#calculateSplit"
                            styleClass="primary-btn"
                            prefWidth="250"/>

                    <TextArea fx:id="resultArea"
                              wrapText="true"
                              prefHeight="200"
                              styleClass="modern-textarea"/>
                </VBox>

            </VBox>
        </center>

    </BorderPane>

</StackPane>